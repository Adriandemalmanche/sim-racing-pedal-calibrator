<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="SimRacingPedalCalibrator.AxisCalibrationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SimRacingPedalCalibrator">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock 
            Grid.Row="0"
            x:Name="AxisNameText"
            Text="Axis Name"
            Style="{StaticResource SubtitleTextBlockStyle}"/>

        <!-- Value Display -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Current Value -->
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Current Value" FontSize="12" Opacity="0.7"/>
                <TextBlock 
                    x:Name="CurrentValueText"
                    Text="0"
                    Style="{StaticResource BodyStrongTextBlockStyle}"/>
            </StackPanel>

            <!-- Min Value -->
            <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Min" FontSize="12" Opacity="0.7"/>
                <TextBlock 
                    x:Name="MinValueText"
                    Text="0"
                    Style="{StaticResource BodyStrongTextBlockStyle}"/>
            </StackPanel>

            <!-- Max Value -->
            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Max" FontSize="12" Opacity="0.7"/>
                <TextBlock 
                    x:Name="MaxValueText"
                    Text="65535"
                    Style="{StaticResource BodyStrongTextBlockStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Progress Bar for Raw Value -->
        <ProgressBar 
            Grid.Row="2"
            x:Name="ValueBar"
            Value="0"
            Maximum="65535"
            Height="8"
            CornerRadius="4"/>

        <!-- Calibration Controls -->
        <Grid Grid.Row="3" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="Min Value" FontSize="12" Opacity="0.7"/>
                <NumberBox 
                    x:Name="MinInput"
                    Minimum="0"
                    Maximum="65535"
                    SpinButtonPlacementMode="Inline"
                    ValueChanged="OnCalibrationValueChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="Max Value" FontSize="12" Opacity="0.7"/>
                <NumberBox 
                    x:Name="MaxInput"
                    Minimum="0"
                    Maximum="65535"
                    SpinButtonPlacementMode="Inline"
                    ValueChanged="OnCalibrationValueChanged"/>
            </StackPanel>
        </Grid>

        <!-- Dead Zone Control -->
        <StackPanel Grid.Row="4" Spacing="8">
            <TextBlock Text="Dead Zone" FontSize="12" Opacity="0.7"/>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Slider 
                    Grid.Column="0"
                    x:Name="DeadZoneSlider"
                    Minimum="0"
                    Maximum="10000"
                    Value="0"
                    ValueChanged="OnDeadZoneChanged"/>
                <TextBlock 
                    Grid.Column="1"
                    x:Name="DeadZoneValue"
                    Text="0"
                    VerticalAlignment="Center"
                    TextAlignment="Right"/>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
